# PostPilot AI Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# AWS Configuration
# ============================================

# AWS Region where resources are deployed
AWS_REGION=us-east-1

# AWS Account ID (for resource naming)
AWS_ACCOUNT_ID=123456789012

# ============================================
# DynamoDB Tables
# ============================================

# DynamoDB table names (auto-populated by SAM/CloudFormation)
DYNAMODB_USERS_TABLE=postpilot-users
DYNAMODB_PRODUCTS_TABLE=postpilot-products
DYNAMODB_CAMPAIGNS_TABLE=postpilot-campaigns
DYNAMODB_ANALYTICS_TABLE=postpilot-analytics
DYNAMODB_MEMORY_TABLE=postpilot-memory
DYNAMODB_RATE_LIMITS_TABLE=postpilot-rate-limits

# DynamoDB endpoint (use for local development with DynamoDB Local)
# DYNAMODB_ENDPOINT=http://localhost:8000

# ============================================
# S3 Storage
# ============================================

# S3 bucket for media storage
S3_BUCKET_NAME=postpilot-media-123456789012

# S3 endpoint (use for local development with LocalStack)
# S3_ENDPOINT=http://localhost:4566

# ============================================
# SQS Queue
# ============================================

# SQS queue URL for campaign publishing
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/postpilot-publishing-queue

# SQS endpoint (use for local development with LocalStack)
# SQS_ENDPOINT=http://localhost:4566

# ============================================
# Amazon Bedrock
# ============================================

# Bedrock model ID for AI agents
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Bedrock region (may differ from main AWS region)
BEDROCK_REGION=us-east-1

# Bedrock timeout settings (seconds)
BEDROCK_CONNECTION_TIMEOUT=5
BEDROCK_RESPONSE_TIMEOUT=15

# ============================================
# Amazon Rekognition
# ============================================

# Rekognition minimum confidence threshold
REKOGNITION_MIN_CONFIDENCE=75

# Rekognition timeout settings (seconds)
REKOGNITION_CONNECTION_TIMEOUT=5
REKOGNITION_RESPONSE_TIMEOUT=10

# ============================================
# Instagram API
# ============================================

# Instagram OAuth credentials (store in AWS Secrets Manager in production)
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/v1/instagram/callback

# Instagram API version
INSTAGRAM_API_VERSION=v18.0

# Instagram API timeout settings (seconds)
INSTAGRAM_CONNECTION_TIMEOUT=10
INSTAGRAM_RESPONSE_TIMEOUT=30

# ============================================
# Authentication & Security
# ============================================

# JWT secret key (store in AWS Secrets Manager in production)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT token expiry times (seconds)
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600      # 60 minutes
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800   # 7 days

# Bcrypt password hashing cost factor
BCRYPT_COST_FACTOR=12

# Encryption key name in AWS Secrets Manager
ENCRYPTION_KEY_SECRET_NAME=postpilot/encryption-key

# ============================================
# Rate Limiting & Quotas
# ============================================

# Rate limit: requests per minute per user
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Daily campaign generation quota per user
DAILY_CAMPAIGN_QUOTA=50

# Token bucket refill rate (tokens per second)
RATE_LIMIT_REFILL_RATE=1.67  # 100 tokens per 60 seconds

# ============================================
# Retry & Circuit Breaker Configuration
# ============================================

# Maximum retry attempts for external API calls
MAX_RETRY_ATTEMPTS=3

# Exponential backoff base delay (seconds)
RETRY_BASE_DELAY=1

# Circuit breaker failure threshold
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Circuit breaker timeout (seconds)
CIRCUIT_BREAKER_TIMEOUT=60

# ============================================
# Logging & Monitoring
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable structured JSON logging
STRUCTURED_LOGGING=true

# Enable distributed tracing
TRACE_ENABLED=true

# CloudWatch log retention (days)
LOG_RETENTION_DAYS=30

# ============================================
# Application Settings
# ============================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# API base URL
API_BASE_URL=https://api.postpilot.ai

# Frontend URL (for CORS)
FRONTEND_URL=https://app.postpilot.ai

# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=10485760  # 10 MB

# Allowed image formats
ALLOWED_IMAGE_FORMATS=image/jpeg,image/png

# Campaign scheduling limits
MAX_SCHEDULE_DAYS_AHEAD=90

# Analytics collection interval (hours)
ANALYTICS_COLLECTION_INTERVAL=6

# ============================================
# Local Development Only
# ============================================

# Use local AWS services (LocalStack)
# USE_LOCAL_AWS=false

# LocalStack endpoint
# LOCALSTACK_ENDPOINT=http://localhost:4566

# FastAPI development server settings
# FASTAPI_HOST=0.0.0.0
# FASTAPI_PORT=8000
# FASTAPI_RELOAD=true
